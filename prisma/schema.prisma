generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Item {
  id          String   @id @default(uuid()) @db.Uuid
  title       String // описание книги / статьи (не название)
  description String // оформление источника по ГОСТ (название уже внутри)
  createdAt   DateTime @default(now())
}
