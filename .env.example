# Neon PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Рабочая БД для view-db
DATABASE_URL_PROD="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Auth.js — сгенерировать: openssl rand -base64 32
AUTH_SECRET="your-auth-secret"

# URL приложения (локально)
AUTH_URL="http://localhost:3001"

# На Vercel: AUTH_URL="https://your-domain.vercel.app"

# Google OAuth — см. AUTH_SETUP.md
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# view-db на production (опционально)
# VIEW_DB_ENABLED=1
