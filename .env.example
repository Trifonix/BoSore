# Neon PostgreSQL connection string (локальная / dev)
# Dashboard: https://console.neon.tech → Connection string → Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Рабочая БД для view-db (production Neon)
DATABASE_URL_PROD="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Включить view-db на production (по умолчанию доступен в development)
# VIEW_DB_ENABLED=1
